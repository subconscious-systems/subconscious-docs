{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Subconscious Docs",
  "contextual": {
    "options": [
      "copy",
      "claude",
      "chatgpt"
    ]
  },
  "font": {
    "family": "Manrope",
    "url": "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap"
  },
  "colors": {
    "primary": "#FF5C28",
    "light": "#FF5C28",
    "dark": "#FF5C28"
  },
  "favicon": "/favicon.png",
  "feedback": {
    "thumbsRating": true
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "overview",
              "quickstart",
              "pricing"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/streaming",
              "features/structured-output",
              "features/thinking"
            ]
          },
          {
            "group": "Ways to Use",
            "pages": [
              "enterprise/cloud-api",
              "enterprise/dedicated",
              "enterprise/on-prem",
              "enterprise/local-devices",
              "enterprise/privacy"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/learn-more"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "/api-reference/openapi.json"
      }
    ]
  },
  "logo": {
    "light": "/logo/full-logo.svg",
    "dark": "/logo/full-logo.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Platform",
      "href": "https://www.subconscious.dev/platform"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/subsysdev",
      "github": "https://github.com/subconscious-systems/subconscious-docs",
      "linkedin": "https://linkedin.com/company/subsysdev"
    }
  },
